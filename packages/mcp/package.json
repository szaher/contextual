{
  "name": "@ctxl/mcp",
  "version": "0.1.0",
  "description": "MCP server providing 10 context management tools over stdio",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/szaher/contextual.git",
    "directory": "packages/mcp"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./client.js": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "bin": {
    "ctxkit-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@ctxl/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.7.0"
  }
}

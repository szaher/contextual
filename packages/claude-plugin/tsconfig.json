{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@ctxl/core": ["../core/dist/index.d.ts", "../core/src/index.ts"],
      "@ctxl/mcp/client": ["../mcp/dist/client.d.ts", "../mcp/src/client.ts"],
      "@ctxl/mcp/client.js": ["../mcp/dist/client.d.ts", "../mcp/src/client.ts"]
    }
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
